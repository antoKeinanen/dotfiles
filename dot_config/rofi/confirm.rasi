/* Confirm Dialog */

@theme "/dev/null"
* {
  background-color: #181825;
  text-color: #cdd6f4;
  font: "JetBrains Mono Medium 10";
}

window {
  width: 225px;
  padding: 25px;
  border: 1px;
  border-radius: 5px;
  border-color: #b4befe;
  location: center;
  y-offset: -2em;
}

entry {
  expand: true;
  text-color: #b4befe;
  border-radius: 5px;
  placeholder: "";
}
